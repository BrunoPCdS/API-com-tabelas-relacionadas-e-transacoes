generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Usuario {
  id                    Int         @id @default(autoincrement())
  nome                  String      @db.VarChar(40) 
  email                 String      @db.VarChar(60) @unique
  senha                 String      @db.VarChar(60)

  criado_em             DateTime    @default(now())
  atualizado_em         DateTime    @updatedAt
  inscricao             Inscricao[]
  logs                  Log[]

  deleted               Boolean     @default(false)
  deletedAt             DateTime?

  ultimoLogin           DateTime?   @db.DateTime

  status                Status      @default(Inativo)
  codigoAtivacao        String?     @unique @db.VarChar(100)

  codigoDeRecuperacao      String?     @db.VarChar(60)
  codigoExpiraEm           DateTime?   // Para recuperação de senha
  dataDeExpiracaoCodigo    DateTime?   @db.DateTime
  @@map("usuarios")
}

model Evento {
  id                    Int        @id @default(autoincrement())
  nome                  String     @db.VarChar(60) 
  descricao             String?    
  data                  DateTime   @db.DateTime
  local                 String     @db.VarChar(60)
  quantidadeIngressos   Int @default(0)
  criado_em             DateTime    @default(now())
  atualizado_em         DateTime    @updatedAt
  ingresso              Ingresso[]
  inscricao             Inscricao[]
  @@map("eventos")
}


model Ingresso {
  id                    Int        @id @default(autoincrement())
  tipo                  Tipos      @default(Pista)
  descricao             String?    
  eventoId              Int        
  evento                Evento     @relation(fields: [eventoId], references: [id])
  criado_em             DateTime    @default(now())
  atualizado_em         DateTime    @updatedAt
  inscricao             Inscricao[]
  @@map("ingressos")
}


model Inscricao {
  id                    Int        @id @default(autoincrement())
  eventoId              Int        
  evento                Evento     @relation(fields: [eventoId], references: [id])
  usuarioId             Int
  usuario               Usuario    @relation(fields: [usuarioId], references: [id])
  ingressoId            Int
  ingresso              Ingresso   @relation(fields: [ingressoId], references: [id])
  criado_em             DateTime    @default(now())
  atualizado_em         DateTime    @updatedAt
  @@map("inscricoes")
}

model Log {
  id                    Int        @id @default(autoincrement())
  descricao             String     @db.VarChar(255)
  usuarioId             Int?
  usuario               Usuario?   @relation(fields: [usuarioId], references: [id])
  criado_em             DateTime    @default(now())

  @@map("logs")
}

enum Status {
  Ativo
  Inativo
}

enum Tipos {
  VIP
  Pista
  MeiaEntrada
}